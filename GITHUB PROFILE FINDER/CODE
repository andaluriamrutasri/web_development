<!DOCTYPE html>
<html>
<head>
    <title>GitHub Profile Finder</title>

    <style>
        body{
            text-align:center;
            font-family:Arial;
            margin-top:50px;
        }

        input,button{
            padding:10px;
        }

        img{
            border-radius:50%;
        }
    </style>
</head>
<body>

<h1>GitHub Profile Finder</h1>

<!-- Username input -->
<input
type="text"
id="username"
placeholder="Enter GitHub Username">

<!-- Calls findProfile() -->
<button onclick="findProfile()">
Search
</button>

<!-- Profile shown here -->
<div id="profile"></div>

<script>

async function findProfile(){

    try{

        // Read username
        const username =
        document.getElementById("username").value;

        // Fetch API request
        const response =
        await fetch(
        `https://api.github.com/users/${username}`
        );

        // Error handling
        if(!response.ok){
            throw new Error("User not found");
        }

        // Convert to JSON
        const user =
        await response.json();

        // Destructuring
        const {
            avatar_url,
            name,
            followers,
            public_repos
        } = user;

        // Spread operator
        const profileCopy = {
            ...user
        };

        // Display profile
        document.getElementById("profile").innerHTML =
        `
        <img src="${avatar_url}" width="150">

        <h2>${name}</h2>

        <p>Followers : ${followers}</p>

        <p>Repositories : ${public_repos}</p>
        `;
    }

    catch(error){

        document.getElementById("profile").innerHTML =
        error.message;
    }
}

</script>

</body>
</html>
