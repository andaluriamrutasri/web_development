<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SpaceX | Landing Page</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, sans-serif;
        }

        body{
            background:black;
            color:white;
        }

        /* Header */
        header{
            position:fixed;
            top:0;
            width:100%;
            padding:25px 50px;
            display:flex;
            align-items:center;
            z-index:100;
            background:rgba(0,0,0,0.4);
        }

        .logo{
            font-size:24px;
            font-weight:bold;
            letter-spacing:5px;
            margin-right:40px;
        }

        nav a{
            color:white;
            text-decoration:none;
            margin-right:20px;
            font-size:13px;
            font-weight:bold;
            text-transform:uppercase;
        }

        nav a:hover{
            color:#ccc;
        }

        /* Hero Sections */
        .hero{
            height:100vh;
            background-size:cover;
            background-position:center;
            display:flex;
            align-items:flex-end;
            padding:0 0 100px 60px;
            position:relative;
        }

        .hero::before{
            content:"";
            position:absolute;
            inset:0;
            background:rgba(0,0,0,0.35);
        }

        .content{
            position:relative;
            z-index:2;
            max-width:500px;
        }

        .content h2{
            font-size:18px;
            margin-bottom:10px;
            text-transform:uppercase;
        }

        .content h1{
            font-size:50px;
            margin-bottom:30px;
            text-transform:uppercase;
        }

        .btn{
            display:inline-block;
            padding:15px 40px;
            border:2px solid white;
            color:white;
            text-decoration:none;
            font-weight:bold;
            text-transform:uppercase;
            transition:0.3s;
        }

        .btn:hover{
            background:white;
            color:black;
        }

        /* Different Sections */
        .hero1{
            background-image:url('https://images.unsplash.com/photo-1446776811953-b23d57bd21aa');
        }

        .hero2{
            background-image:url('https://images.unsplash.com/photo-1516849841032-87cbac4d88f7');
        }

        .hero3{
            background-image:url('https://images.unsplash.com/photo-1451187580459-43490279c0fa');
        }

        .hero4{
            background-image:url('https://images.unsplash.com/photo-1462331940025-496dfbfc7564');
        }

        footer{
            text-align:center;
            padding:25px;
            background:#111;
            font-size:14px;
        }

        /* Mobile */
        @media(max-width:768px){

            header{
                padding:20px;
                flex-direction:column;
                align-items:flex-start;
            }

            nav{
                margin-top:10px;
            }

            nav a{
                display:inline-block;
                margin-bottom:10px;
            }

            .content h1{
                font-size:35px;
            }

            .hero{
                padding:0 20px 80px 20px;
            }
        }
    </style>
</head>

<body>

    <!-- Header -->
    <header>
        <div class="logo">SPACEX</div>

        <nav>
            <a href="#">Falcon 9</a>
            <a href="#">Falcon Heavy</a>
            <a href="#">Dragon</a>
            <a href="#">Starship</a>
        </nav>
    </header>

    <!-- Section 1 -->
    <section class="hero hero1">
        <div class="content">
            <h2>Upcoming Launch</h2>
            <h1>Starlink Mission</h1>
            <a href="https://youtu.be/C3iHAgwIYtI" class="btn" target="_blank">Watch Replay</a>
        </div>
    </section>

    <!-- Section 2 -->
    <section class="hero hero2">
        <div class="content">
            <h2>Falcon Heavy</h2>
            <h1>World's Most Powerful Rocket</h1>
            <a href="https://www.spacex.com/vehicles/falcon-heavy/" class="btn"  target="_blank">Learn More</a>
        </div>
    </section>

    <!-- Section 3 -->
    <section class="hero hero3">
        <div class="content">
            <h2>Dragon Mission</h2>
            <h1>Sending Humans To Space</h1>
            <a href="https://www.spacex.com/vehicles/dragon/" class="btn"  target="_blank">Explore</a>
        </div>
    </section>

    <!-- Section 4 -->
    <section class="hero hero4">
        <div class="content">
            <h2>Future Of Spaceflight</h2>
            <h1>Starship</h1>
            <a href="https://www.spacex.com/vehicles/starship/" class="btn"  target="_blank">Discover</a>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        © 2026 SpaceX Clone Website | Created by Amruta Sri
    </footer>

</body>
</html>
